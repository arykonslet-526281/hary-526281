{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the user who is filling out the form.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "displayName": { "type": "string", "description": "The display name of the user." },
        "email": { "type": "string", "format": "email", "description": "The email of the user." },
        "photoURL": { "type": "string", "description": "The photo URL of the user." }
      },
      "required": ["uid", "email"]
    },
    "InnovationForm": {
      "title": "Regional Innovation Form",
      "description": "A form containing regional innovation profile and indicators.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who created this form." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The time the form was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "The time the form was last updated." },
        "status": { "type": "string", "enum": ["draft", "submitted"], "description": "The status of the form." },
        "profilInovasi": {
          "type": "object",
          "properties": {
            "namaInovasi": { "type": "string" },
            "rancangBangun": { "type": "string", "description": "Minimal 300 kata" },
            "tujuan": { "type": "string" },
            "manfaat": {
              "type": "object",
              "properties": {
                "opd": { "type": "string" },
                "stakeholder": { "type": "string" },
                "masyarakat": { "type": "string" }
              }
            },
            "hasil": { "type": "string" }
          }
        },
        "indikatorInovasi": {
          "type": "object",
          "properties": {
            "regulasi": { "type": "object", "properties": { "value": { "type": "string" }, "fileUrl": { "type": "string" }, "fileName": { "type": "string" } } },
            "sdm": { "type": "object", "properties": { "value": { "type": "string" }, "fileUrl": { "type": "string" }, "fileName": { "type": "string" } } },
            "anggaran": { "type": "object", "properties": { "value": { "type": "string" }, "fileUrl": { "type": "string" }, "fileName": { "type": "string" } } },
            "penggunaanIT": { "type": "object", "properties": { "value": { "type": "string" }, "fileUrl": { "type": "string" }, "fileName": { "type": "string" } } },
            "bimtek": { "type": "object", "properties": { "value": { "type": "string" }, "fileUrl": { "type": "string" }, "fileName": { "type": "string" } } },
            "rkpd": { "type": "object", "properties": { "value": { "type": "string" }, "fileUrl": { "type": "string" }, "fileName": { "type": "string" } } },
            "aktor": { "type": "object", "properties": { "value": { "type": "string" }, "fileUrl": { "type": "string" }, "fileName": { "type": "string" } } },
            "pelaksana": { "type": "object", "properties": { "value": { "type": "string" }, "fileUrl": { "type": "string" }, "fileName": { "type": "string" } } },
            "jejaring": { "type": "object", "properties": { "value": { "type": "string" }, "fileUrl": { "type": "string" }, "fileName": { "type": "string" } } },
            "sosialisasi": { "type": "object", "properties": { "value": { "type": "string" }, "fileUrl": { "type": "string" }, "fileName": { "type": "string" } } },
            "pedoman": { "type": "object", "properties": { "value": { "type": "string" }, "fileUrl": { "type": "string" }, "fileName": { "type": "string" }, "videoUrl": { "type": "string" } } },
            "informasi": { "type": "object", "properties": { "value": { "type": "string" }, "fileUrl": { "type": "string" }, "fileName": { "type": "string" } } },
            "proses": { "type": "object", "properties": { "value": { "type": "string" }, "fileUrl": { "type": "string" }, "fileName": { "type": "string" } } },
            "pengaduan": { "type": "object", "properties": { "value": { "type": "string" }, "fileUrl": { "type": "string" }, "fileName": { "type": "string" } } },
            "online": { "type": "object", "properties": { "value": { "type": "string" }, "fileUrl": { "type": "string" }, "fileName": { "type": "string" } } },
            "replikasi": { "type": "object", "properties": { "value": { "type": "string" }, "fileUrl": { "type": "string" }, "fileName": { "type": "string" } } },
            "kecepatan": { "type": "object", "properties": { "value": { "type": "string" }, "fileUrl": { "type": "string" }, "fileName": { "type": "string" } } },
            "kemanfaatan": { "type": "object", "properties": { "value": { "type": "string" }, "fileUrl": { "type": "string" }, "fileName": { "type": "string" } } },
            "monev": { "type": "object", "properties": { "value": { "type": "string" }, "fileUrl": { "type": "string" }, "fileName": { "type": "string" } } },
            "kualitas": { "type": "object", "properties": { "value": { "type": "string" }, "fileUrl": { "type": "string" }, "fileName": { "type": "string" }, "videoUrl": { "type": "string" } } }
          }
        }
      },
      "required": ["userId", "createdAt", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/innovations/{innovationId}": {
      "schema": "InnovationForm",
      "description": "Regional innovation form documents."
    }
  }
}
